# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the Fintoc–Bancolombia backend
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# Then load it before starting the server:
#   export $(cat .env | xargs) && uvicorn main:app --reload
# ─────────────────────────────────────────────────────────────────────────────

# Your Fintoc SECRET key (starts with "sk_live_" or "sk_test_").
# Found in: Fintoc dashboard → Settings → API Keys
FINTOC_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_SECRET_KEY

# Google Sheets spreadsheet ID.
# The long string in: https://docs.google.com/spreadsheets/d/<ID>/edit
SPREADSHEET_ID=REPLACE_WITH_YOUR_SPREADSHEET_ID

# Sheet tab name and optional starting cell for appended rows.
SHEET_RANGE=Movimientos!A1

# Path to the Google Service Account JSON key file (relative to backend/).
GOOGLE_CREDENTIALS_FILE=credentials.json

# How many days back to fetch movements (default: 3).
DAYS_BACK=3

# Comma-separated list of frontend origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
